# Copy this file to .env. Existing shell/container variables take precedence.

# Collection target
KIRS_RESEARCH_URL=https://www.kirs.or.kr/research/research22_1.html
REPORT_TYPE=KIRS_RESEARCH
MAX_PAGES=1

# Identify your organization and a monitored contact address.
CRAWLER_USER_AGENT=InternalResearchCollector/1.0 (+contact: admin@example.com)
REQUEST_TIMEOUT_SECONDS=30
REQUEST_DELAY_SECONDS=1.5
DOWNLOAD_RETRIES=3

# Keep robots.txt checks enabled.
RESPECT_ROBOTS_TXT=true

# Daily schedule
SCHEDULE_HOUR=7
SCHEDULE_MINUTE=0
SCHEDULE_TIMEZONE=Asia/Seoul

# Optional paths
# DATABASE_PATH=/absolute/path/to/db/reports.db
# PDF_STORAGE_PATH=/absolute/path/to/storage/raw_pdfs
# LOG_DIR=/absolute/path/to/logs
